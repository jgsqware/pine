# {{ ansible_managed }}
# Acme Corp chrony configuration

{% for server in ntp_servers %}
pool {{ server }} iburst
{% endfor %}

driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony
maxupdateskew 100.0

# Only serve time to the local segment
{% if 'monitoring' in group_names %}
allow 10.0.0.0/16
{% else %}
# client only
{% endif %}
