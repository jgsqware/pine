# {{ ansible_managed }}
# vhost: {{ item.server_name }}

server {
    listen {{ item.listen_port }};
    server_name {{ item.server_name }};

    access_log {{ item.access_log }} acme;
    root {{ item.root }};

{% if item.upstream_port | int > 0 %}
    location / {
        proxy_pass http://127.0.0.1:{{ item.upstream_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    location /static/ {
        alias {{ item.root }}/static/;
        expires 7d;
        add_header Cache-Control "public";
    }
{% else %}
    location / {
        try_files $uri $uri/ =404;
        expires 1d;
    }
{% endif %}

    location /healthz {
        access_log off;
        return 200 "ok {{ item.server_name }}\n";
        add_header Content-Type text/plain;
    }
}
