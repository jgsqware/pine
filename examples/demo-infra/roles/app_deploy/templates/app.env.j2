# {{ ansible_managed }}
# Environment for {{ app_name }} on {{ inventory_hostname }}
DJANGO_SETTINGS_MODULE=acme_shop.settings.production
SECRET_KEY={{ vault_app_secret_key }}
INTERNAL_API_TOKEN={{ vault_app_api_token }}
ALLOWED_HOSTS=shop.{{ acme_domain | default('acme-corp.example') }},{{ ansible_host | default(inventory_hostname) }}
DATABASE_URL=postgresql://{{ app_db_user }}:{{ vault_pg_app_password }}@{{ app_db_host }}:5432/{{ app_db_name }}
REDIS_URL=redis://:{{ vault_redis_password }}@{{ app_redis_host }}:6379/0
GUNICORN_WORKERS={{ app_workers }}
GUNICORN_BIND=127.0.0.1:{{ app_port }}
LOG_DIR={{ app_base_dir }}/shared/log
RELEASE_CHANNEL={{ app_release_channel | default('stable') }}
ENVIRONMENT={{ env_name | default('production') }}
