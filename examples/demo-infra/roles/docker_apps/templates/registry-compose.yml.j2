# {{ ansible_managed }}
# Acme internal registry + MinIO object storage stack
name: acme-registry

services:
  registry:
    image: "registry:{{ registry_image_tag }}"
    restart: unless-stopped
    ports:
      - "{{ registry_port }}:5000"
    environment:
      REGISTRY_STORAGE: s3
      REGISTRY_STORAGE_S3_REGIONENDPOINT: "http://minio:{{ minio_api_port }}"
      REGISTRY_STORAGE_S3_BUCKET: acme-registry
      REGISTRY_STORAGE_S3_ACCESSKEY: "{{ vault_minio_root_user }}"
      REGISTRY_STORAGE_S3_SECRETKEY: "{{ vault_minio_root_password }}"
      REGISTRY_STORAGE_S3_SECURE: "false"
      REGISTRY_AUTH: htpasswd
      REGISTRY_AUTH_HTPASSWD_REALM: "Acme Registry"
      REGISTRY_AUTH_HTPASSWD_PATH: /auth/htpasswd
    volumes:
      - registry-auth:/auth
    depends_on:
      minio:
        condition: service_healthy

  minio:
    image: "minio/minio:{{ minio_image_tag }}"
    restart: unless-stopped
    command: ["server", "/data", "--console-address", ":{{ minio_console_port }}"]
    environment:
      MINIO_ROOT_USER: "{{ vault_minio_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ vault_minio_root_password }}"
    ports:
      - "{{ minio_api_port }}:9000"
      - "{{ minio_console_port }}:9001"
    volumes:
      - minio-data:/data
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 20s
      timeout: 5s
      retries: 5

volumes:
  registry-auth: {}
  minio-data: {}
